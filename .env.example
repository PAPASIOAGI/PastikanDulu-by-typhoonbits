# =============================================================================
# PastikanDulu — Environment Variables
# =============================================================================

# GEMINI_API_KEY: Required for Gemini AI API calls.
# Get your key from: https://aistudio.google.com/apikey
# IMPORTANT: Never commit your actual API key! Keep this file as .env.example only.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where this app is hosted (used for CORS policy).
# Set this to your production domain when deploying.
# Leave empty for local development (defaults to http://localhost:3000).
# APP_URL="https://your-production-domain.com"

# NODE_ENV: Set to "production" when deploying.
# NODE_ENV="production"
